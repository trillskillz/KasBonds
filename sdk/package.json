{
  "name": "@ksb/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Initial SDK for the Kaspa Service Bonds API",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "examples:typecheck": "tsc -p tsconfig.examples.json"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
