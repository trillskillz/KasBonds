# Base URL of the KSB protocol instance to integrate against.
KSB_BASE_URL=http://localhost:3000

# Operator key. Required to register an app and to dispatch the verifier hub.
KSB_OPERATOR_API_KEY=

# Optional: reuse an already registered app instead of registering a new one.
# When unset, the reference registers a fresh app on each run.
KSB_APP_API_KEY=

# The agent endpoint the SLA bond promises to keep reachable.
AGENT_HEALTH_URL=https://api.example.com/health

# Bond parties (Kaspa addresses).
PROVIDER_ADDRESS=kaspa:provider-agent
COUNTERPARTY_ADDRESS=kaspa:consumer-agent
