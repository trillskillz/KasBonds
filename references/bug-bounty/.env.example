# Base URL of the KSB protocol instance to integrate against.
KSB_BASE_URL=http://localhost:3000

# Operator key. Required to register an app.
KSB_OPERATOR_API_KEY=

# Optional: reuse an already registered app instead of registering a new one.
KSB_APP_API_KEY=

# Where the researcher's disclosure write-up is published.
REPORT_URL=https://disclosures.example.com/report-42

# Bond parties (Kaspa addresses).
SPONSOR_ADDRESS=kaspa:sponsor
RESEARCHER_ADDRESS=kaspa:researcher
