# Base URL of the KSB protocol instance to integrate against.
KSB_BASE_URL=http://localhost:3000

# Operator key. Required to register an app and to dispatch the verifier hub.
KSB_OPERATOR_API_KEY=

# Optional: reuse an already registered app instead of registering a new one.
KSB_APP_API_KEY=

# Bond parties (Kaspa addresses). The committer stakes the bond; the
# accountability party is the counterparty compensated on a slash.
COMMITTER_ADDRESS=kaspa:committer
ACCOUNTABILITY_ADDRESS=kaspa:accountability-partner

# Optional: commitment deadline and claimed completion time, both unix
# seconds. When unset the deadline defaults to 7 days out and completion to
# now, so the demo run resolves to a pass.
DEADLINE_UNIX=
COMPLETED_AT_UNIX=
