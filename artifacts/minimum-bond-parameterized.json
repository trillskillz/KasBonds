        "span": "entrypoint function slash(sig slashSig) {\n        require(checkSig(slashSig, slashKey));\n        require(tx.time >= deadline);\n        require(tx.outputs.length == 3);\n\n        int currentValue = tx.inputs[this.activeInputIndex].value;\n        int distributable = currentValue - minerFee;\n        int buyerAmount = distributable * 50 / 100;\n        int platformFeeAmount = distributable * 5 / 100;\n        int burnAmount = distributable - buyerAmount - platformFeeAmount;\n\n        require(tx.outputs[0].scriptPubKey == byte[](new ScriptPubKeyP2PK(buyerKey)));\n        require(tx.outputs[0].value == buyerAmount);\n\n        require(tx.outputs[1].scriptPubKey == byte[](new ScriptPubKeyP2PK(platformFeeKey)));\n        require(tx.outputs[1].value == platformFeeAmount);\n\n        require(tx.outputs[2].scriptPubKey == byte[](new ScriptPubKeyP2PK(burnKey)));\n        require(tx.outputs[2].value == burnAmount);\n    }",
