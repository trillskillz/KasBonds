    "span": "contract X402Channel(\n    pubkey client,\n    int initTimeout,\n    int initNonce\n) {\n    int timeout = initTimeout;\n    int nonce = initNonce;\n\n    entrypoint function settle(sig clientSig, sig facilitatorSig) {\n        pubkey facilitator = 0x25d0720065a2eebebb85fbfb6d8dab952fa7c3cafdb0f6166953b0dfc9bd8dc3;\n\n        require(checkSig(clientSig, client));\n        require(checkSig(facilitatorSig, facilitator));\n\n        int inputValue = tx.inputs[this.activeInputIndex].value;\n        int paymentAmount = tx.outputs[0].value;\n        int minerFee = 5000;\n\n        require(paymentAmount > 0);\n        require(paymentAmount + minerFee <= inputValue);\n\n        int remainder = inputValue - paymentAmount - minerFee;\n\n        if (remainder > minerFee) {\n            validateOutputState(1, { nonce: nonce + 1, timeout: timeout });\n            require(tx.outputs[1].value == remainder);\n        }\n    }\n}",
