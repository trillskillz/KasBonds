pragma silverscript ^0.1.0;

// x402 Payment Channel for Kaspa L1
//
// A 2-of-2 escrow covenant enabling HTTP 402 micropayments.
// Client locks KAS into this covenant. To pay for a resource,
// the client partially signs a settlement TX. The facilitator
// verifies and co-signs to complete settlement.
//
// Supports multi-payment via state transitions:
//   settle() pays server and returns change to same covenant
//   with updated nonce (preventing replay).

contract X402Channel(
    pubkey client,          // Client's x-only public key (32 bytes)
    pubkey facilitator,     // Facilitator's x-only public key (32 bytes)
    int initTimeout,        // Absolute timestamp for refund eligibility
    int initNonce           // Initial nonce (replay protection)
) {
    // State fields — these can be updated via validateOutputState
    int timeout = initTimeout;
    int nonce = initNonce;

    // settle: Pay a server for a resource
    // Both client and facilitator must sign.
    // Output[0] = payment to server
    // Output[1] = change back to same covenant with nonce+1 (if funds remain)
    entrypoint function settle(sig clientSig, sig facilitatorSig) {
        require(checkSig(clientSig, client));
        require(checkSig(facilitatorSig, facilitator));

        int inputValue = tx.inputs[this.activeInputIndex].value;
        int paymentAmount = tx.outputs[0].value;
        int minerFee = 5000;

        require(paymentAmount > 0);
        require(paymentAmount + minerFee <= inputValue);

        int remainder = inputValue - paymentAmount - minerFee;

        if (remainder > minerFee) {
            validateOutputState(1, { nonce: nonce + 1, timeout: timeout });
            require(tx.outputs[1].value == remainder);
        }
    }

    // refund: Client reclaims funds after timeout
    entrypoint function refund(sig clientSig) {
        require(checkSig(clientSig, client));
        require(tx.time >= timeout);
    }
}
