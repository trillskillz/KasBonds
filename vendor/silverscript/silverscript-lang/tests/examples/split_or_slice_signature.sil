pragma silverscript ^0.1.0;

contract Test(sig signature) {
    entrypoint function spend() {
        // Assume Schnorr
        byte[] hashtype1 = signature.split(64).1;
        byte[1] hashtype2 = signature.slice(64, 65);
        require(hashtype1 == byte[](0x01));
        require(hashtype2 == 0x01);
    }
}
