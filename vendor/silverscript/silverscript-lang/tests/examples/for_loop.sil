contract ForLoop() {
    int constant START = 0;
    int constant END = 4;
    int constant MAX_ITERATIONS = 4;
    int constant MIN_OUT = 1000;

    entrypoint function check() {
        for(i, START, END, MAX_ITERATIONS) {
            require(tx.outputs[i].value >= MIN_OUT + i);
        }
    }
}
