contract Decls(int max_ins, int max_outs) {
    int value = 0;

    #[covenant(from = max_ins, to = max_outs, mode = verification)]
    function transition_ok(State[] prev_states, State[] new_states, int delta) {
        require(delta >= 0);
    }
}

// --- lowered ---

contract Decls(int max_ins, int max_outs) {
    int value = 0;

    function covenant_policy_transition_ok(State[] prev_states, State[] new_states, int delta) {
        require(delta >= 0);
    }

    entrypoint function leader_transition_ok(State[] new_states, int delta) {
        byte[32] cov_id = OpInputCovenantId(this.activeInputIndex);

        require(OpCovInputIdx(cov_id, 0) == this.activeInputIndex);

        int cov_in_count = OpCovInputCount(cov_id);
        require(cov_in_count <= max_ins);

        int cov_out_count = OpCovOutputCount(cov_id);
        State[] prev_states;

        for(cov_in_k, 0, cov_in_count, max_ins) {
            prev_states = prev_states.append(readInputState(OpCovInputIdx(cov_id, cov_in_k)));
        }

        covenant_policy_transition_ok(prev_states, new_states, delta);
        require(cov_out_count <= max_outs);
        require(cov_out_count == new_states.length);

        for(cov_k, 0, cov_out_count, max_outs) {
            int cov_out_idx = OpCovOutputIdx(cov_id, cov_k);
            validateOutputState(cov_out_idx, new_states[cov_k]);
        }
    }

    entrypoint function delegate_transition_ok() {
        byte[32] cov_id = OpInputCovenantId(this.activeInputIndex);

        require(OpCovInputIdx(cov_id, 0) != this.activeInputIndex);
    }
}
